# Database Connection Strings
# Standard local development
DATABASE_URL="postgresql://user:password@localhost:5432/carenow_db?schema=public"

# Vercel Postgres (Add these to Vercel Project Settings)
POSTGRES_URL="postgresql://default:password@ep-quiet-grass-123456.us-east-1.aws.neon.tech/verceldb?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://default:password@ep-quiet-grass-123456-pooler.us-east-1.aws.neon.tech/verceldb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://default:password@ep-quiet-grass-123456.us-east-1.aws.neon.tech/verceldb?sslmode=require"
POSTGRES_USER="default"
POSTGRES_HOST="ep-quiet-grass-123456.us-east-1.aws.neon.tech"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="verceldb"

# SMTP Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CareBridge <no-reply@carebridge.app>"

PORT=4000
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development

# Interswitch Credentials
INTERSWITCH_CLIENT_ID=your_interswitch_client_id
INTERSWITCH_CLIENT_SECRET=your_interswitch_client_secret
INTERSWITCH_BASE_URL=https://qa.interswitchng.com
INTERSWITCH_PAY_ITEM_ID=your_pay_item_id
INTERSWITCH_MERCHANT_CODE=your_merchant_code

# Frontend URL for redirect
FRONTEND_URL=http://localhost:5800
